@model IEnumerable<BoutiquePortal.Model.Models.Order>

@{
    Layout = "~/Areas/Shop/Views/Shared/_ShopLayout.cshtml";
    ViewBag.Title = "My Orders";
}

<style>
    .mo-page-title {
        font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 6px;
        letter-spacing: -.3px;
    }

    .mo-subtitle {
        font-size: 14px;
        color: #888;
        margin-bottom: 28px;
    }

    .mo-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        margin-bottom: 24px;
        overflow: hidden;
        border: 1px solid #f0f0f0;
        font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
    }

    .mo-card-header {
        background: #f8f9fa;
        border-bottom: 1px solid #eee;
        padding: 16px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
    }

    .mo-order-id {
        font-size: 15px;
        font-weight: 700;
        color: #2c3e50;
    }

    .mo-order-date {
        font-size: 12px;
        color: #999;
        margin-top: 2px;
    }

    .mo-badge {
        display: inline-block;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: .3px;
    }

    .mo-badge-pending {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffc107;
    }

    .mo-badge-confirmed {
        background: #cfe2ff;
        color: #084298;
        border: 1px solid #b6d4fe;
    }

    .mo-badge-shipped {
        background: #d1ecf1;
        color: #0c5460;
        border: 1px solid #bee5eb;
    }

    .mo-badge-delivered {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .mo-badge-cancelled {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .mo-badge-paid {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .mo-meta-row {
        padding: 14px 24px;
        background: #fdfdfd;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        gap: 32px;
        flex-wrap: wrap;
        align-items: center;
    }

    .mo-meta-item label {
        display: block;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #aaa;
        margin-bottom: 3px;
        font-weight: 600;
    }

    .mo-meta-item span {
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }

    .mo-total-amount {
        margin-left: auto;
        text-align: right;
    }

        .mo-total-amount label {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: #aaa;
            margin-bottom: 3px;
            font-weight: 600;
        }

        .mo-total-amount span {
            font-size: 20px;
            font-weight: 700;
            color: #e74c3c;
        }

    .mo-items-title {
        padding: 16px 24px 8px;
        font-size: 12px;
        font-weight: 700;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: .7px;
        border-bottom: 1px solid #f5f5f5;
    }

    .mo-item-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 24px;
        border-bottom: 1px solid #f9f9f9;
        transition: background .15s;
    }

        .mo-item-row:last-child {
            border-bottom: none;
        }

        .mo-item-row:hover {
            background: #fafafa;
        }

    .mo-item-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #eee;
        flex-shrink: 0;
    }

    .mo-item-img-placeholder {
        width: 70px;
        height: 70px;
        border-radius: 8px;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        flex-shrink: 0;
        border: 1px solid #eee;
    }

    .mo-item-info {
        flex: 1;
        min-width: 0;
    }

    .mo-item-name {
        font-size: 15px;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 3px;
    }

    .mo-item-brand {
        font-size: 12px;
        color: #999;
        margin-bottom: 3px;
    }

    .mo-item-vendor {
        font-size: 12px;
        color: #bbb;
    }

    .mo-item-size {
        display: inline-block;
        background: #e74c3c;
        color: #fff;
        padding: 2px 10px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        margin-top: 5px;
    }

    .mo-item-qty-price {
        text-align: right;
        flex-shrink: 0;
    }

    .mo-item-qty {
        font-size: 12px;
        color: #888;
        margin-bottom: 4px;
    }

    .mo-item-total {
        font-size: 15px;
        font-weight: 700;
        color: #2c3e50;
    }

    .mo-empty {
        text-align: center;
        padding: 80px 20px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
    }

    .mo-empty-icon {
        font-size: 64px;
        margin-bottom: 16px;
        opacity: .45;
    }

    .mo-empty h3 {
        font-size: 22px;
        font-weight: 700;
        color: #555;
        margin-bottom: 8px;
    }

    .mo-empty p {
        font-size: 14px;
        color: #aaa;
        margin-bottom: 24px;
    }

    @@media(max-width:576px) {

        .mo-card-header,
        .mo-meta-row,
        .mo-item-row {
            padding-left: 16px;
            padding-right: 16px;
        }

        .mo-total-amount {
            margin-left: 0;
        }

        .mo-item-img,
        .mo-item-img-placeholder {
            width: 56px;
            height: 56px;
        }
    }
</style>

<div class="container" style="padding:36px 0 60px;">

    <div class="mo-page-title">My Orders</div>
    <p class="mo-subtitle">Track and review all your past purchases</p>

    @if (!Model.Any())
    {
        <div class="mo-empty">
            <div class="mo-empty-icon">🛍️</div>

            <h3>No orders yet</h3>

            <p>
                Looks like you haven't placed any orders yet.
            </p>

            <a href="/Shop/Shop"
               class="btn btn-primary btn-lg px-5">
                Browse Products
            </a>
        </div>
    }
    else
    {
        foreach (var order in Model)
        {
            var badgeClass = "mo-badge-pending";

            switch (order.OrderStatus)
            {
                case "Pending":
                    badgeClass = "mo-badge-pending";
                    break;

                case "Confirmed":
                    badgeClass = "mo-badge-confirmed";
                    break;

                case "Shipped":
                    badgeClass = "mo-badge-shipped";
                    break;

                case "Delivered":
                    badgeClass = "mo-badge-delivered";
                    break;

                case "Cancelled":
                    badgeClass = "mo-badge-cancelled";
                    break;
            }

            <div class="mo-card">

                <!-- ORDER HEADER -->
                <div class="mo-card-header">

                    <div>
                        <div class="mo-order-id">
                            Order #@order.OrderId
                        </div>

                        <div class="mo-order-date">
                            Placed on
                            @order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")
                        </div>
                    </div>

                    <span class="mo-badge @badgeClass">
                        @order.OrderStatus
                    </span>

                </div>

                <!-- META INFO -->
                <div class="mo-meta-row">

                    <div class="mo-meta-item">
                        <label>Payment Method</label>

                        <span>
                            @if (order.PaymentMethod == "COD")
                            {
                                <text>🚚 Cash on Delivery</text>
                            }
                            else if (order.PaymentMethod == "UPI")
                            {
                                <text>📱 UPI</text>
                            }
                            else
                            {
                                <text>💳 Card</text>
                            }
                        </span>
                    </div>

                    <div class="mo-meta-item">
                        <label>Payment Status</label>

                        <span class="mo-badge @(order.PaymentStatus == "Paid" ? "mo-badge-paid" : "mo-badge-pending")"
                              style="font-size:11px; padding:3px 10px;">
                            @order.PaymentStatus
                        </span>
                    </div>

                    <div class="mo-meta-item">
                        <label>Shipping To</label>

                        <span>
                            @order.ShippingCity, @order.ShippingState
                        </span>
                    </div>

                    <div class="mo-total-amount">
                        <label>Order Total</label>

                        <span>
                            &#8377;@order.TotalAmount.ToString("N2")
                        </span>
                    </div>

                </div>

                <!-- ITEMS -->
                @if (order.Items != null && order.Items.Any())
                {
                    <div class="mo-items-title">
                        @order.Items.Count Item@(order.Items.Count > 1 ? "s" : "") Ordered
                    </div>

                    foreach (var item in order.Items)
                    {
                        <div class="mo-item-row">

                            <!-- IMAGE -->
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="~/images/product/@item.ImagePath"
                                     class="mo-item-img"
                                     alt="@item.ProductName"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />

                                <div class="mo-item-img-placeholder"
                                     style="display:none;">
                                    👕
                                </div>
                            }
                            else
                            {
                                <div class="mo-item-img-placeholder">
                                    👕
                                </div>
                            }

                            <!-- INFO -->
                            <div class="mo-item-info">

                                <div class="mo-item-name">
                                    @item.ProductName
                                </div>

                                @if (!string.IsNullOrEmpty(item.BrandName))
                                {
                                    <div class="mo-item-brand">
                                        Brand: @item.BrandName
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(item.VendorName))
                                {
                                    <div class="mo-item-vendor">
                                        Sold by: @item.VendorName
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(item.SelectedSize))
                                {
                                    <span class="mo-item-size">
                                        Size: @item.SelectedSize
                                    </span>
                                }

                            </div>

                            <!-- PRICE -->
                            <div class="mo-item-qty-price">

                                <div class="mo-item-qty">
                                    @item.Quantity × ₹@item.UnitPrice.ToString("0.00")
                                </div>

                                <div class="mo-item-total">
                                    ₹@item.TotalPrice.ToString("N2")
                                </div>

                            </div>

                        </div>
                    }
                }
                else
                {
                    <div style="padding:18px 24px; color:#bbb; font-size:13px;">
                        Item details unavailable for this order.
                    </div>
                }

            </div>
        }
    }

    <div style="text-align:center; margin-top:8px;">
        <a href="/Shop/Shop"
           class="btn btn-outline-secondary px-4">
            ← Continue Shopping
        </a>
    </div>

</div>
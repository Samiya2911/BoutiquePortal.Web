@model BoutiquePortal.Model.ViewModels.CheckoutVM
@using BoutiquePortal.Model.Models
@{
    Layout = "~/Areas/Shop/Views/Shared/_ShopLayout.cshtml";
    ViewBag.Title = "Checkout";
    var cart = ViewBag.Cart as List<CartItem> ?? new List<CartItem>();
}

<div class="container">
    <div class="check">
        <h1>Checkout</h1>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger small py-2">
                @foreach (var error in ViewData.ModelState.Values
                            .SelectMany(v => v.Errors))
                {
                    <div>⚠️ @error.ErrorMessage</div>
                }
            </div>
        }

        <form method="post" action="/Shop/Checkout" id="CheckoutForm">
            @Html.AntiForgeryToken()

            <div class="col-md-9 cart-items">

                <!-- ======= STEP 1: SHIPPING INFO ======= -->
                <div class="cart-header" style="padding:20px;">
                    <h3 style="border-bottom:2px solid #eee; padding-bottom:10px;
                           margin-bottom:20px;">
                        📦 Shipping Information
                    </h3>

                    <div class="row">
                        <div class="col-md-6" style="margin-bottom:15px;">
                            <label style="font-weight:600; display:block;
                                      margin-bottom:5px;">
                                Full Name *
                            </label>
                            <input type="text" name="ShippingName"
                                   value="@Model.ShippingName"
                                   class="form-control"
                                   placeholder="Enter full name" />
                            <span class="text-danger small">
                                @Html.ValidationMessage("ShippingName")
                            </span>
                        </div>

                        <div class="col-md-6" style="margin-bottom:15px;">
                            <label style="font-weight:600; display:block;
                                      margin-bottom:5px;">
                                Phone *
                            </label>
                            <input type="text" name="ShippingPhone"
                                   value="@Model.ShippingPhone"
                                   class="form-control"
                                   placeholder="9876543210" />
                            <span class="text-danger small">
                                @Html.ValidationMessage("ShippingPhone")
                            </span>
                        </div>
                    </div>

                    <div style="margin-bottom:15px;">
                        <label style="font-weight:600; display:block;
                                  margin-bottom:5px;">
                            Full Address *
                        </label>
                        <textarea name="ShippingAddress"
                                  class="form-control" rows="2"
                                  placeholder="House No, Street, Area...">@Model.ShippingAddress</textarea>
                        <span class="text-danger small">
                            @Html.ValidationMessage("ShippingAddress")
                        </span>
                    </div>

                    <div class="row">
                        <div class="col-md-4" style="margin-bottom:15px;">
                            <label style="font-weight:600; display:block;
                                      margin-bottom:5px;">
                                City *
                            </label>
                            <input type="text" name="ShippingCity"
                                   value="@Model.ShippingCity"
                                   class="form-control"
                                   placeholder="City" />
                            <span class="text-danger small">
                                @Html.ValidationMessage("ShippingCity")
                            </span>
                        </div>

                        <div class="col-md-4" style="margin-bottom:15px;">
                            <label style="font-weight:600; display:block;
                                      margin-bottom:5px;">
                                State *
                            </label>
                            <input type="text" name="ShippingState"
                                   value="@Model.ShippingState"
                                   class="form-control"
                                   placeholder="State" />
                            <span class="text-danger small">
                                @Html.ValidationMessage("ShippingState")
                            </span>
                        </div>

                        <div class="col-md-4" style="margin-bottom:15px;">
                            <label style="font-weight:600; display:block;
                                      margin-bottom:5px;">
                                Pincode *
                            </label>
                            <input type="text" name="ShippingPincode"
                                   value="@Model.ShippingPincode"
                                   class="form-control"
                                   placeholder="380001" />
                            <span class="text-danger small">
                                @Html.ValidationMessage("ShippingPincode")
                            </span>
                        </div>
                    </div>
                </div>

                <!-- ======= STEP 2: PAYMENT METHOD ======= -->
                <div class="cart-header" style="padding:20px; margin-top:15px;">
                    <h3 style="border-bottom:2px solid #eee; padding-bottom:10px;
                           margin-bottom:20px;">
                        💳 Payment Method
                    </h3>

                    <!-- Payment Options -->
                    <div style="display:flex; gap:15px; flex-wrap:wrap;
                            margin-bottom:20px;">

                        <!-- COD -->
                        <label style="flex:1; min-width:140px; cursor:pointer;">
                            <div class="payment-option" id="opt-COD"
                                 style="border:2px solid #ddd; border-radius:10px;
                                    padding:15px; text-align:center;
                                    transition:all 0.2s;">
                                <input type="radio" name="PaymentMethod"
                                       value="COD" id="pay-COD"
                                       checked
                                       style="display:none;"
                                       onchange="showPaymentFields('COD')" />
                                <div style="font-size:2rem;">🚚</div>
                                <div style="font-weight:600; margin-top:5px;">
                                    Cash on Delivery
                                </div>
                                <div style="font-size:11px; color:#888;">
                                    Pay when delivered
                                </div>
                            </div>
                        </label>

                        <!-- UPI -->
                        <label style="flex:1; min-width:140px; cursor:pointer;">
                            <div class="payment-option" id="opt-UPI"
                                 style="border:2px solid #ddd; border-radius:10px;
                                    padding:15px; text-align:center;
                                    transition:all 0.2s;">
                                <input type="radio" name="PaymentMethod"
                                       value="UPI" id="pay-UPI"
                                       style="display:none;"
                                       onchange="showPaymentFields('UPI')" />
                                <div style="font-size:2rem;">📱</div>
                                <div style="font-weight:600; margin-top:5px;">
                                    UPI Payment
                                </div>
                                <div style="font-size:11px; color:#888;">
                                    GPay / PhonePe / Paytm
                                </div>
                            </div>
                        </label>

                        <!-- Card -->
                        <label style="flex:1; min-width:140px; cursor:pointer;">
                            <div class="payment-option" id="opt-Card"
                                 style="border:2px solid #ddd; border-radius:10px;
                                    padding:15px; text-align:center;
                                    transition:all 0.2s;">
                                <input type="radio" name="PaymentMethod"
                                       value="Card" id="pay-Card"
                                       style="display:none;"
                                       onchange="showPaymentFields('Card')" />
                                <div style="font-size:2rem;">💳</div>
                                <div style="font-weight:600; margin-top:5px;">
                                    Debit / Credit Card
                                </div>
                                <div style="font-size:11px; color:#888;">
                                    Visa / Mastercard
                                </div>
                            </div>
                        </label>

                    </div>

                    <!-- COD Fields -->
                    <div id="fields-COD" class="payment-fields">
                        <div style="background:#f0fff0; border:1px solid #c3e6cb;
                                border-radius:8px; padding:15px;">
                            <p style="margin:0; color:#155724;">
                                ✅ You will pay <strong>&#8377;@Model.GrandTotal.ToString("N2")</strong>
                                when your order is delivered.
                            </p>
                        </div>
                    </div>

                    <!-- UPI Fields -->
                    <div id="fields-UPI" class="payment-fields"
                         style="display:none;">
                        <div style="background:#fff3cd; border:1px solid #ffc107;
                                border-radius:8px; padding:15px;">
                            <label style="font-weight:600; display:block;
                                      margin-bottom:8px;">
                                UPI ID *
                            </label>
                            <input type="text" name="UpiId"
                                   id="UpiId"
                                   class="form-control"
                                   placeholder="yourname@upi or 9876543210@paytm"
                                   style="max-width:350px;" />
                            <span class="text-danger small"
                                  id="err-UpiId"></span>
                            <p style="margin-top:8px; font-size:12px; color:#856404;">
                                📌 Enter your UPI ID to proceed.
                                Amount will be deducted on confirmation.
                            </p>
                        </div>
                    </div>

                    <!-- Card Fields -->
                    <div id="fields-Card" class="payment-fields"
                         style="display:none;">
                        <div style="background:#e7f3ff; border:1px solid #b8daff;
                                border-radius:8px; padding:15px;">

                            <div class="row">
                                <div class="col-md-8 mb-3">
                                    <label style="font-weight:600; display:block;
                                              margin-bottom:5px;">
                                        Card Number *
                                    </label>
                                    <input type="text" name="CardNumber"
                                           id="CardNumber"
                                           class="form-control"
                                           placeholder="1234 5678 9012 3456"
                                           maxlength="19"
                                           oninput="formatCard(this)" />
                                    <span class="text-danger small"
                                          id="err-CardNumber"></span>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label style="font-weight:600; display:block;
                                              margin-bottom:5px;">
                                        CVV *
                                    </label>
                                    <input type="password" name="CardCvv"
                                           class="form-control"
                                           placeholder="•••"
                                           maxlength="3" />
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label style="font-weight:600; display:block;
                                              margin-bottom:5px;">
                                        Name on Card *
                                    </label>
                                    <input type="text" name="CardName"
                                           id="CardName"
                                           class="form-control"
                                           placeholder="As printed on card" />
                                    <span class="text-danger small"
                                          id="err-CardName"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label style="font-weight:600; display:block;
                                              margin-bottom:5px;">
                                        Expiry Date *
                                    </label>
                                    <input type="text" name="CardExpiry"
                                           class="form-control"
                                           placeholder="MM/YY"
                                           maxlength="5"
                                           oninput="formatExpiry(this)" />
                                </div>
                            </div>

                            <p style="font-size:12px; color:#004085;">
                                🔒 Your card details are encrypted and secure.
                            </p>
                        </div>
                    </div>

                </div>

                <!-- ======= ORDER ITEMS SUMMARY ======= -->
                <div class="cart-header" style="padding:20px; margin-top:15px;">
                    <h3 style="border-bottom:2px solid #eee; padding-bottom:10px;
                           margin-bottom:15px;">
                        🛒 Order Summary (@cart.Count item@(cart.Count != 1 ? "s" : ""))
                    </h3>

                    @foreach (var item in cart)
                    {
                        <div class="cart-sec" style="margin-bottom:12px;">
                            <div class="cart-item cyc">
                                @if (!string.IsNullOrEmpty(item.ProductImage))
                                {
                                    <img src="~/images/product/@item.ProductImage"
                                         class="img-responsive"
                                         style="width:60px; height:60px;
                                                    object-fit:cover; border-radius:6px;"
                                         onerror="this.src='/shop/images/pic1.jpg'"
                                         alt="@item.ProductName" />
                                }
                                else
                                {
                                    <img src="~/shop/images/pic1.jpg"
                                         style="width:60px; height:60px;
                                                    object-fit:cover; border-radius:6px;"
                                         alt="@item.ProductName" />
                                }
                            </div>
                            <div class="cart-item-info">
                                <h3 style="font-size:14px;">
                                    @item.ProductName
                                    <span style="font-weight:400; color:#888;">
                                        @item.BrandName
                                    </span>
                                </h3>
                                <ul class="qty">
                                    <li>
                                        <p>
                                            Qty: @item.Quantity ×
                                            &#8377;@item.ActualPrice.ToString("0.00") =
                                            <strong>&#8377;@item.SubTotal.ToString("N2")</strong>
                                        </p>
                                    </li>
                                </ul>
                            </div>
                            <div class="clearfix"></div>
                        </div>
                    }
                </div>

            </div>

            <!-- ======= RIGHT: PRICE DETAILS ======= -->
            <div class="col-md-3 cart-total">

                <a class="continue" href="/Shop/Cart">← Edit Cart</a>

                <div class="price-details">
                    <h3>Price Details</h3>

                    <span>Sub Total</span>
                    <span class="total1">
                        &#8377;@Model.SubTotal.ToString("N2")
                    </span>

                    <span>Delivery Charges</span>
                    <span class="total1">
                        &#8377;@Model.DeliveryCharge.ToString("N2")
                    </span>

                    <div class="clearfix"></div>
                </div>

                <ul class="total_price">
                    <li class="last_price"><h4>TOTAL</h4></li>
                    <li class="last_price">
                        <span>&#8377;@Model.GrandTotal.ToString("N2")</span>
                    </li>
                    <div class="clearfix"></div>
                </ul>

                <!-- Place Order Button -->
                <button type="submit" class="order"
                        id="PlaceOrderBtn"
                        style="width:100%; height:10000%; border:none; cursor:pointer; background-color:#ff7a18; color:purple;" ">
                    Place Order 🎉
                </button>

                <div class="total-item">
                    <h3>SECURE PAYMENT</h3>
                    <p style="font-size:12px; color:#888;">
                        🔒 Your payment info is encrypted and safe.
                    </p>
                    <p style="font-size:12px; color:#888;">
                        📦 Expected delivery in 3-5 business days.
                    </p>
                </div>

            </div>

            <div class="clearfix"></div>

        </form>

    </div>
</div>

@section Scripts {
    <script>
        // ======= PAYMENT METHOD TOGGLE =======
        function showPaymentFields(method) {
            // Hide all
            document.querySelectorAll('.payment-fields')
                    .forEach(el => el.style.display = 'none');

            // Reset borders
            document.querySelectorAll('.payment-option')
                    .forEach(el => {
                        el.style.border      = '2px solid #ddd';
                        el.style.background  = 'white';
                    });

            // Show selected
            var fieldsEl = document.getElementById('fields-' + method);
            if (fieldsEl) fieldsEl.style.display = 'block';

            // Highlight selected option
            var optEl = document.getElementById('opt-' + method);
            if (optEl) {
                optEl.style.border     = '2px solid #007bff';
                optEl.style.background = '#f0f7ff';
            }

            // Check the radio
            var radio = document.getElementById('pay-' + method);
            if (radio) radio.checked = true;
        }

        // ======= CLICK ON PAYMENT OPTION BOX =======
        document.querySelectorAll('.payment-option').forEach(function (el) {
            el.addEventListener('click', function () {
                var method = this.id.replace('opt-', '');
                showPaymentFields(method);
            });
        });

        // ======= FORMAT CARD NUMBER =======
        function formatCard(input) {
            var val = input.value.replace(/\D/g, '').substring(0, 16);
            input.value = val.replace(/(.{4})/g, '$1 ').trim();
        }

        // ======= FORMAT EXPIRY =======
        function formatExpiry(input) {
            var val = input.value.replace(/\D/g, '').substring(0, 4);
            if (val.length >= 3)
                input.value = val.substring(0, 2) + '/' + val.substring(2);
            else
                input.value = val;
        }

        // ======= FORM VALIDATION =======
        document.getElementById('CheckoutForm')
                .addEventListener('submit', function (e) {

            var method = document.querySelector(
                             'input[name="PaymentMethod"]:checked')?.value;

            if (method === 'UPI') {
                var upiId = document.getElementById('UpiId').value.trim();
                if (!upiId) {
                    e.preventDefault();
                    document.getElementById('err-UpiId').textContent =
                        'UPI ID is required';
                    document.getElementById('UpiId').focus();
                    return;
                }
            }

            if (method === 'Card') {
                var cardNo = document.getElementById('CardNumber').value.trim();
                var cardName = document.getElementById('CardName').value.trim();
                if (!cardNo || !cardName) {
                    e.preventDefault();
                    if (!cardNo)
                        document.getElementById('err-CardNumber').textContent =
                            'Card number is required';
                    if (!cardName)
                        document.getElementById('err-CardName').textContent =
                            'Name on card is required';
                    return;
                }
            }

            // Show loading on button
            var btn = document.getElementById('PlaceOrderBtn');
            btn.textContent = 'Placing Order...';
            btn.disabled    = true;
        });

        // ======= INIT: highlight COD by default =======
        showPaymentFields('COD');
    </script>
}
@model BoutiquePortal.Model.Models.Product
@{
    Layout = "~/Areas/Shop/Views/Shared/_ShopLayout.cshtml";
    ViewBag.Title = Model.ProductName;
}

<div class="product">
    <div class="container" style="padding: 30px 0;">

        <div class="row">

            <!-- ======= LEFT: Product Image ======= -->
            <div class="col-md-5">
                @if (!string.IsNullOrEmpty(Model.ProductImage))
                {
                    <img src="~/images/product/@Model.ProductImage"
                         class="img-responsive"
                         style="width:100%; border-radius:8px;
                                        box-shadow: 0 4px 15px rgba(0,0,0,0.1);"
                         onerror="this.src='/shop/images/product1.jpg'"
                         alt="@Model.ProductName" />
                }
                else
                {
                    <img src="~/shop/images/product1.jpg"
                         class="img-responsive"
                         style="width:100%; border-radius:8px;" />
                }
            </div>

            <!-- ======= RIGHT: Product Info ======= -->
            <div class="col-md-7" style="padding-left:30px;">

                <h2 style="margin-bottom:5px;">@Model.ProductName</h2>
                <p style="color:#888; margin-bottom:10px;">
                    Brand: <strong>@Model.BrandName</strong> |
                    Category: <strong>@Model.CategoryName</strong>
                </p>

                <!-- Price -->
                <div style="margin: 15px 0;">
                    @if (Model.DiscountPrice.HasValue && Model.DiscountPrice > 0)
                    {
                        <span style="font-size:16px; text-decoration:line-through; color:#999;">
                            &#8377;@Model.Price.ToString("0.00")
                        </span>
                        <span style="font-size:26px; font-weight:bold; color:#e74c3c; margin-left:10px;">
                            &#8377;@Model.DiscountPrice.Value.ToString("0.00")
                        </span>
                        <span style="background:#e74c3c; color:white; padding:3px 8px;
                                             border-radius:4px; font-size:12px; margin-left:8px;">
                            SALE
                        </span>
                    }
                    else
                    {
                        <span style="font-size:26px; font-weight:bold; color:#333;">
                            &#8377;@Model.Price.ToString("0.00")
                        </span>
                    }
                </div>

                <!-- Stock -->
                @*  <p style="margin-bottom:15px;">
                    @if (Model.Quantity > 0)
                    {
                        <span style="color:green;">
                            ✅ In Stock (@Model.Quantity available)
                        </span>
                    }
                    else
                    {
                        <span style="color:red;">❌ Out of Stock</span>
                    }
                </p> *@

                <div style="margin: 15px 0;">
                    @if (Model.Quantity > 0)
                    {
                        <span style="color: green; font-weight: 600;">
                            ✅ In Stock
                            <span style="color: #888; font-weight: 400; font-size: 13px;">
                                (@Model.Quantity available)
                            </span>
                        </span>
                    }
                    else
                    {
                        <span style="color: red; font-weight: 600;">
                            ❌ Out of Stock
                        </span>
                    }
                </div>


                <!-- ======= SIZE SELECTOR ======= -->
                @{
                    var sizes = ViewBag.ProductSizes as
                    IEnumerable<BoutiquePortal.Model.Models.ProductSize>;
                }

                @if (sizes != null && sizes.Any())
                {
                    <div style="margin: 15px 0;">
                        <p style="font-weight:600; margin-bottom:10px;">
                            Select Size: <span id="selected-size-label"
                                               style="color:#e74c3c;"></span>
                        </p>

                        <div style="display:flex; gap:8px; flex-wrap:wrap;
                            margin-bottom:5px;">
                            @foreach (var s in sizes)
                            {
                                <button type="button"
                                        onclick="selectSize(this, '@s.SizeName', @s.Quantity)"
                                        class="size-btn"
                                        data-size="@s.SizeName"
                                        data-qty="@s.Quantity"
                                        style="padding:8px 18px; border:2px solid #ddd;
                                               background:white; border-radius:6px;
                                               cursor:pointer; font-weight:600;
                                               font-size:14px; transition:all 0.2s;
                                               @(s.Quantity == 0
                                                                                                                   ? "opacity:0.4; cursor:not-allowed;"
                                                                                                                   : "")">
                            @s.SizeName
                            @if (s.Quantity == 0)
                                    {
                                        <br />
                                        <small style="font-size:10px; color:#e74c3c;">
                                            Out
                                        </small>
                                    }
                                </button>
                            }
                        </div>

                        <small id="size-stock-info"
                               style="color:#888; font-size:12px;">
                        </small>
                        <small id="err-size"
                               style="color:#e74c3c; font-size:12px; display:block;">
                        </small>
                    </div>
                }

                <!-- Hidden size field for Add to Cart link -->
                <input type="hidden" id="selected-size-val" value="" />

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div style="margin: 15px 0; line-height:1.7; color:#555;">
                        <h5>Description</h5>
                        <p>@Model.Description</p>
                    </div>
                }

                <!-- Vendor -->
                <p style="color:#888; font-size:13px;">
                    Sold by: <strong>@Model.VendorName</strong>
                </p>

                <hr />

                <!-- ======= BUY BUTTON ======= -->
                @*  @if (Model.Quantity > 0)
                {
                    @if (Context.Session.GetString("Role") == "Customer")
                    {
                        <div style="display:flex; align-items:center;
                            gap:10px; margin-bottom:15px;">
                            <label style="font-weight:600;">Qty:</label>
                            <button onclick="changeQty(-1)"
                                    style="width:32px; height:32px;
                                   border:1px solid #ddd;
                                   background:#f5f5f5;
                                   cursor:pointer; border-radius:4px;">
                                −
                            </button>
                            <span id="qty-display"
                                  style="font-size:18px; font-weight:bold;
                                 min-width:30px; text-align:center;">
                                1
                            </span>
                            <button onclick="changeQty(1)"
                                    style="width:32px; height:32px;
                                   border:1px solid #ddd;
                                   background:#f5f5f5;
                                   cursor:pointer; border-radius:4px;">
                                +
                            </button>
                            <span style="color:#888; font-size:12px;">
                                Max: @Model.Quantity
                            </span>
                        </div>

                        <a id="add-to-cart-btn"
                           href="/Shop/Cart/Add/@Model.ProductId?qty=1"
                           class="btn btn-primary btn-lg"
                           style="margin-right:10px;">
                            🛒 Add to Cart
                        </a>
                    }
                    else
                    {
                        <a href="/Customer/CustomerAccount/Login"
                           class="btn btn-primary btn-lg">
                            Login to Buy
                        </a>
                    }
                }
                else
                {
                    <!-- ✅ Out of Stock button -->
                    <button class="btn btn-secondary btn-lg" disabled
                            style="cursor: not-allowed;">
                        ❌ Out of Stock
                    </button>
                    <p style="color:#e74c3c; font-size:13px; margin-top:8px;">
                        This product is currently unavailable.
                        Check back later!

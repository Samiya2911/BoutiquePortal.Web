                <a href="/Shop/Shop" class="btn btn-outline-secondary btn-lg">
                    ← Back to Shop
                </a> *@


                <!-- NEW SIZE SELECTOR SCRIPT Samiya  Add to Cart button  -->
                @if (Model.Quantity > 0)
                {
                    @if (Context.Session.GetString("Role") == "Customer")
                    {
                        <!-- Quantity selector -->
                        <div style="display:flex; align-items:center;
                                    gap:10px; margin-bottom:15px;">
                            <label style="font-weight:600;">Qty:</label>
                            <button onclick="changeQty(-1)"
                                    style="width:32px; height:32px; border:1px solid #ddd;
                                           background:#f5f5f5; cursor:pointer;
                                           border-radius:4px; font-size:16px;">
                                −
                            </button>
                            <span id="qty-display"
                                  style="font-size:18px; font-weight:bold;
                                         min-width:30px; text-align:center;">1</span>
                            <button onclick="changeQty(1)"
                                    style="width:32px; height:32px; border:1px solid #ddd;
                                           background:#f5f5f5; cursor:pointer;
                                           border-radius:4px; font-size:16px;">
                                +
                            </button>
                        </div>

                        <!-- ✅ Add to Cart with size -->
                        <button onclick="addToCart()"
                                class="btn btn-primary btn-lg"
                                style="margin-right:10px;">
                            🛒 Add to Cart
                        </button>
                    }
                    else
                    {
                        <a href="/Customer/CustomerAccount/Login"
                           class="btn btn-primary btn-lg">
                            Login to Buy
                        </a>
                    }
                }

                <a href="/Shop/Shop" class="btn btn-outline-secondary btn-lg">
                    ← Back to Shop
                </a>

                <!-- NEW SIZE SELECTOR SCRIPT  -->
                @*  @section Scripts {
                    <script>
                        var qty    = 1;
                        var maxQty = @Model.Quantity;

                        function changeQty(delta) {
                            qty = Math.max(1, Math.min(maxQty, qty + delta));
                            document.getElementById('qty-display').textContent = qty;
                            document.getElementById('add-to-cart-btn').href =
                                '/Shop/Cart/Add/@Model.ProductId?qty=' + qty;
                        }
                    </script> *@

                @section Scripts {
                    <script>
                            var qty         = 1;
                            var maxQty      = @Model.Quantity;
                            var selectedSize = '';
                            var hasSizes    = @((sizes != null && sizes.Any())
                                                                                                                                                                                ? "true" : "false");

                    function changeQty(delta) {
                        qty = Math.max(1, Math.min(maxQty, qty + delta));
                        document.getElementById('qty-display').textContent = qty;
                    }

                            function selectSize(btn, sizeName, sizeQty) {
                                if (sizeQty <= 0) return;  // can't select out-of-stock size

                                // Reset all buttons
                                document.querySelectorAll('.size-btn').forEach(function (b) {
                                    b.style.border     = '2px solid #ddd';
                                    b.style.background = 'white';
                                    b.style.color      = '#333';
                                });

                                // Highlight selected
                                btn.style.border     = '2px solid #e74c3c';
                                btn.style.background = '#e74c3c';
                                btn.style.color      = 'white';

                                selectedSize = sizeName;
                                document.getElementById('selected-size-val').value = sizeName;
                                document.getElementById('selected-size-label').textContent = sizeName;
                                document.getElementById('size-stock-info').textContent =
                                    sizeQty + ' in stock for this size';
                                document.getElementById('err-size').textContent = '';

                                // Update max qty for selected size
                                maxQty = sizeQty;
                                if (qty > maxQty) qty = maxQty;
                                document.getElementById('qty-display').textContent = qty;
                            }

                            // function addToCart() {
                            //     // If product has sizes, must select one
                            //     if (hasSizes && !selectedSize) {
                            //         document.getElementById('err-size').textContent =
                            //             '⚠️ Please select a size first!';
                            //         document.getElementById('err-size').style.display = 'block';
                            //         return;
                            //     }

                            //     var url = '/Shop/Cart/Add/@Model.ProductId?qty=' + qty;
                            //     if (selectedSize)
                            //         url += '&size=' + encodeURIComponent(selectedSize);

                            //     window.location.href = url;
                            // }

                            function addToCart() {
                            if (hasSizes && !selectedSize) {
                                document.getElementById('err-size').textContent =
                                    '⚠️ Please select a size first!';
                                return;
                            }

                            var url = '/Shop/Cart/Add/@Model.ProductId?qty=' + qty;

                            // ✅ Size gets passed in URL
                            if (selectedSize)
                                url += '&size=' + encodeURIComponent(selectedSize);

                            window.location.href = url;
                        }
                    </script>
                                
                }
            </div>

        </div>

    </div>
</div>
@model IEnumerable<BoutiquePortal.Model.Models.Product>
@{
    Layout = "~/Areas/Shop/Views/Shared/_ShopLayout.cshtml";
    ViewBag.Title = "Shop";
}

<div class="product">
    <div class="container">

        <!-- ======= LEFT SIDEBAR ======= -->
        <div class="col-md-3 product-price">
            <div class="rsidebar span_1_of_left">

                <!-- CATEGORIES -->
                <div class="of-left">
                    <h3 class="cate">Categories</h3>
                </div>

                <ul class="menu" id="category-menu">

                    <!-- All Products -->
                    <li class="@(ViewBag.SelectedCategory == null ? "item1" : "")">
                        <a href="/Shop/Shop"
                           style="@(ViewBag.SelectedCategory == null
                                                          ? "color:#e74c3c; font-weight:bold;"
                                                          : "")">
                            All Products
                        </a>
                    </li>

                    @if (ViewBag.Categories != null)
                    {
                        int idx = 1;
                        foreach (var cat in ViewBag.Categories)
                        {
                            bool isSelected = ViewBag.SelectedCategory != null
                            && ViewBag.SelectedCategory == cat.CategoryId;
                            <li class="item@(idx++)">
                                <!-- ✅ Direct href — no JS interference -->
                                <a href="/Shop/Shop?categoryId=@cat.CategoryId"
                                   style="@(isSelected
                                                                          ? "color:#e74c3c; font-weight:bold;"
                                                                          : "")">
                            @cat.CategoryName
                        </a>
                    </li>
                                        }
                    }
                </ul>

                <!-- SEARCH -->
                <div class="product-middle">
                    <div class="fit-top">
                        <h6 class="shop-top">Search Products</h6>
                        <div class="clearfix"></div>
                    </div>
                </div>

                <!-- FILTER -->
                <div class="sellers">
                    <div class="of-left-in">
                        <h3 class="tag">Filter</h3>
                    </div>
                    <div class="tags">
                        <form action="/Shop/Shop" method="get"
                              id="SearchForm">
                            <input type="text"
                                   name="q"
                                   id="search-input"
                                   value="@ViewBag.SearchQuery"
                                   placeholder="Search..."
                                   style="width:100%; padding:8px 10px;
                                          border:1px solid #ddd;
                                          border-radius:4px;
                                          font-size:13px;
                                          margin-bottom:8px;" />

                            @if (ViewBag.SelectedCategory != null)
                            {
                                <input type="hidden"
                                       name="categoryId"
                                       value="@ViewBag.SelectedCategory" />
                            }

                            <button type="submit"
                                    style="width:100%; background:#e74c3c;
                                           color:white; border:none;
                                           padding:9px; border-radius:4px;
                                           cursor:pointer; font-size:13px;
                                           font-weight:600;">
                                🔍 Search
                            </button>
                        </form>
                    </div>
                </div>

                <!-- ACTIVE FILTER INFO -->
                @if (ViewBag.SelectedCategory != null ||
                                !string.IsNullOrEmpty(ViewBag.SearchQuery as string))
                {
                    <div style="margin-top:15px; padding:10px;
                                    background:#fff3cd; border-radius:6px;
                                    font-size:12px; color:#856404;">
                        <strong>Active Filter:</strong><br />
                        @if (ViewBag.SelectedCategory != null)
                        {
                            <span>📁 Category selected</span>
                    
                            <br />
                        }
                        @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
                        {
                            <span>🔍 "@ViewBag.SearchQuery"</span>
                    
                            <br />
                        }
                        <a href="/Shop/Shop"
                           style="color:#e74c3c; text-decoration:none;
                                      font-weight:600;">
                            ✕ Clear Filter
                        </a>
                    </div>
                }

            </div>
        </div>

        <!-- ======= RIGHT PRODUCT GRID ======= -->
        <div class="col-md-9 product1">

            <!-- Product Count -->
            @if (Model.Any())
            {
                <p style="color:#888; font-size:13px;
                               margin-bottom:15px; padding-top:5px;">
                    Showing <strong>@Model.Count()</strong>
                    product@(Model.Count() != 1 ? "s" : "")
                    @if (ViewBag.SelectedCategory != null)
                    {
                        <span>in selected category</span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
                    {
                        <span>for "@ViewBag.SearchQuery"</span>
                    }
                </p>
            }

            @if (!Model.Any())
            {
                <div style="text-align:center; padding:60px 20px;">
                    <div style="font-size:3rem; margin-bottom:15px;">🔍</div>
                    <h4 style="color:#999;">No products found</h4>
                    <p style="color:#bbb;">
                        Try a different search or browse all products.
                    </p>
                    <a href="/Shop/Shop"
                       style="display:inline-block; background:#e74c3c;
                                  color:white; padding:10px 25px;
                                  border-radius:6px; text-decoration:none;
                                  font-weight:600; margin-top:10px;">
                        View All Products
                    </a>
                </div>
            }
            else
            {
                int i = 0;
                foreach (var item in Model)
                {
                    if (i % 3 == 0 && i > 0)
                    {
                        <div class="clearfix"></div>
                    }
                    i++;

                    <div class="col-md-4 bottom-cd simpleCart_shelfItem">
                        <div class="product-at"
                             style="position:relative;">

                            <a href="/Shop/Product/Details/@item.ProductId">
                                @if (!string.IsNullOrEmpty(item.ProductImage))
                                {
                                    <img class="img-responsive"
                                         src="~/images/product/@item.ProductImage"
                                         alt="@item.ProductName"
                                         style="height:220px; object-fit:cover;
                                                            @(item.Quantity == 0
                                                                                             ? "filter:grayscale(80%); opacity:0.6;"
                                                                                             : "")"
                             onerror="this.src='/shop/images/pi.jpg'" />
                                                }
                                else
                                {
                                    <img class="img-responsive"
                                         src="~/shop/images/pi.jpg"
                                         alt="@item.ProductName"
                                         style="height:220px; object-fit:cover;
                                                            @(item.Quantity == 0
                                                                                             ? "filter:grayscale(80%); opacity:0.6;"
                                                                                             : "")" />
                                                }

                                @* Out of Stock Badge *@
                                @if (item.Quantity == 0)
                                {
                                    <div style="position:absolute; top:10px;
                                                            right:10px; background:#e74c3c;
                                                            color:white; padding:4px 10px;
                                                            border-radius:4px; font-size:11px;
                                                            font-weight:bold; z-index:1;">
                                        Out of Stock
                                    </div>
                                }

                        <div class="pro-grid">
                            <span class="buy-in">
                                @(item.Quantity > 0
                                                                ? "View Details"
                                                                : "Out of Stock")
                            </span>
                        </div>
                    </a>
                </div>

                        <!-- Product Name -->
                        <p class="tun">
                            <a href="/Shop/Product/Details/@item.ProductId"
                               style="color:inherit; text-decoration:none;">
                                @item.ProductName
                            </a>
                        </p>

                        <!-- Brand -->
                        <p style="font-size:12px; color:#888;
                                          margin-bottom:5px;">
                            @item.BrandName
                        </p>

                        <!-- Price -->
                        <p class="number item_price">
                    @if (item.DiscountPrice.HasValue && item.DiscountPrice > 0)
                            {
                                <span style="text-decoration:line-through;
                                 color:#999; font-size:13px;">
                                    &#8377;@(item.Price.ToString("0.00"))
                                </span>
                                <span style="color:#e74c3c; font-weight:bold;
                                 margin-left:5px;">
                                    &#8377;@(item.DiscountPrice.Value.ToString("0.00"))
                                </span>
                            }
                            else
                            {
                                <span style="color:#333; font-weight:bold;">
                                    &#8377;@(item.Price.ToString("0.00"))
                                </span>
                            }
                        </p>

                        <!-- Button -->
                        @if (item.Quantity > 0)
                        {
                            <a href="/Shop/Product/Details/@item.ProductId"
                               class="btn btn-sm btn-primary mb-3">
                                View Details
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-secondary mb-3"
                                    disabled>
                                Out of Stock
                            </button>
                        }

                    </div>
                }
                <div class="clearfix"></div>
            }

        </div>

        <div class="clearfix"></div>
    </div>
</div>

@section Scripts {
    <script>
        // ✅ NO e.preventDefault() — categories navigate normally
        // Only highlight active category in sidebar
        document.querySelectorAll('#category-menu a').forEach(function (link) {
            link.addEventListener('mouseenter', function () {
                if (!this.style.fontWeight ||
                    this.style.fontWeight !== 'bold') {
                    this.style.color = '#e74c3c';
                }
            });
            link.addEventListener('mouseleave', function () {
                if (!this.style.fontWeight ||
                    this.style.fontWeight !== 'bold') {
                    this.style.color = '';
                }
            });
        });
    </script>
}
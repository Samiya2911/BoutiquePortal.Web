@model BoutiquePortal.Model.ViewModels.VendorLoginVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Vendor Login — Boutique</title>
    <link href="~/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg,#11998e,#38ef7d);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 20px 50px rgba(0,0,0,.2);
            max-width: 400px;
            width: 100%;
        }

        .card-header {
            background: linear-gradient(135deg,#11998e,#2ecc71);
            color: white;
            border-radius: 16px 16px 0 0 !important;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-header p-4 text-center">
            <h4 class="mb-0">🏪 Vendor Login</h4>
            <small class="opacity-75">Access your vendor dashboard</small>
        </div>
        <div class="card-body p-4">

            @if (TempData["SuccessMsg"] != null)
            {
                <div class="alert alert-success small py-2">@TempData["SuccessMsg"]</div>
            }

            <form asp-area="Vendor" asp-controller="VendorAccount" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label small">Remember Me</label>
                </div>

                @Html.ValidationSummary(true, "", new { @class = "text-danger small" })

                <button type="submit" class="btn btn-success w-100">Login</button>
                <a asp-area="Vendor" asp-controller="VendorAccount" asp-action="Register"
                   class="btn btn-outline-success w-100 mt-2">New Vendor? Register Here</a>
                <a href="/" class="btn btn-link w-100 text-center small">← Back to Portal</a>
            </form>
        </div>
    </div>
</body>
</html>
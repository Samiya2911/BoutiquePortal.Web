@model BoutiquePortal.Model.ViewModels.VendorRegisterVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Vendor Registration — Boutique</title>
    <link href="~/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg,#667eea,#764ba2);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 0;
        }

        .card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 20px 50px rgba(0,0,0,.25);
            max-width: 580px;
            width: 100%;
        }

        .card-header {
            background: linear-gradient(135deg,#667eea,#764ba2);
            color: white;
            border-radius: 16px 16px 0 0 !important;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-header p-4 text-center">
            <h4 class="mb-0">📝 Vendor Registration</h4>
            <small class="opacity-75">Submit your details — Admin will approve your account</small>
        </div>
        <div class="card-body p-4">
            <form asp-area="Vendor" asp-controller="VendorAccount" asp-action="Register"
                  method="post" id="RegisterForm">
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="VendorName" class="form-label">Vendor Name *</label>
                        <input asp-for="VendorName" class="form-control" />
                        <span asp-validation-for="VendorName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="BrandName" class="form-label">Brand Name *</label>
                        <input asp-for="BrandName" class="form-control" />
                        <span asp-validation-for="BrandName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Email *</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label">Phone *</label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Address</label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>

                <!-- COUNTRY / STATE / CITY (same AJAX pattern as Admin) -->
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Country *</label>
                        <select id="CountryId" name="CountryId" class="form-control">
                            <option value="">-- Country --</option>
                            @foreach (var c in ViewBag.Country)
                            {
                                <option value="@c.CountryId">@c.CountryName</option>
                            }
                        </select>
                        <span asp-validation-for="CountryId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">State *</label>
                        <select id="StateId" name="StateId" class="form-control" disabled>
                            <option value="">-- State --</option>
                        </select>
                        <span asp-validation-for="StateId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">City *</label>
                        <select id="CityId" name="CityId" class="form-control" disabled>
                            <option value="">-- City --</option>
                        </select>
                        <span asp-validation-for="CityId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label">Password *</label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password *</label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                @Html.ValidationSummary(true, "", new { @class = "text-danger small" })

                <button type="submit" class="btn btn-primary w-100">Submit Registration</button>
                <a asp-area="Vendor" asp-controller="VendorAccount" asp-action="Login"
                   class="btn btn-link w-100 text-center small">Already registered? Login</a>
            </form>
        </div>
    </div>

    <script>
        // Reuse same AJAX pattern as your Admin vendor.js
        var countryDdl = document.getElementById('CountryId');
        var stateDdl   = document.getElementById('StateId');
        var cityDdl    = document.getElementById('CityId');

        countryDdl.addEventListener('change', function () {
            loadStates(this.value);
        });
        stateDdl.addEventListener('change', function () {
            loadCities(this.value);
        });

        function loadStates(countryId) {
            stateDdl.innerHTML = '<option>Loading...</option>';
            stateDdl.disabled = true;
            cityDdl.innerHTML = '<option value="">-- City --</option>';
            cityDdl.disabled = true;
            if (!countryId) { stateDdl.innerHTML='<option value="">-- State --</option>'; stateDdl.disabled=false; return; }
            fetch('/Vendor/VendorAccount/GetStatesByCountry?countryId=' + countryId)
                .then(r => r.json()).then(data => {
                    stateDdl.innerHTML = '<option value="">-- State --</option>';
                    data.forEach(s => stateDdl.innerHTML += `<option value="${s.stateId}">${s.stateName}</option>`);
                    stateDdl.disabled = false;
                });
        }

        function loadCities(stateId) {
            cityDdl.innerHTML = '<option>Loading...</option>';
            cityDdl.disabled = true;
            if (!stateId) { cityDdl.innerHTML='<option value="">-- City --</option>'; cityDdl.disabled=false; return; }
            fetch('/Vendor/VendorAccount/GetCitiesByState?stateId=' + stateId)
                .then(r => r.json()).then(data => {
                    cityDdl.innerHTML = '<option value="">-- City --</option>';
                    data.forEach(c => cityDdl.innerHTML += `<option value="${c.cityId}">${c.cityName}</option>`);
                    cityDdl.disabled = false;
                });
        }
    </script>
</body>
</html>



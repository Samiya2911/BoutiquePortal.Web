@model BoutiquePortal.Model.ViewModels.ResetPasswordVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Reset Password — Boutique</title>
    <link href="~/assets/vendor/bootstrap/css/bootstrap.min.css"
          rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #11998e, #38ef7d);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 20px 50px rgba(0,0,0,.2);
            max-width: 420px;
            width: 100%;
        }

        .card-header {
            background: linear-gradient(135deg, #11998e, #2ecc71);
            color: white;
            border-radius: 16px 16px 0 0 !important;
            padding: 1.5rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">🔒 Reset Password</h4>
            <small class="opacity-75">Enter your new password</small>
        </div>

        <div class="card-body p-4">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger small py-2">
                    @foreach (var error in ViewData.ModelState.Values
                                    .SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post"
                  action="/Vendor/VendorAccount/ResetPassword">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Token" value="@Model.Token" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        New Password
                    </label>
                    <input type="password"
                           name="NewPassword"
                           class="form-control"
                           placeholder="Min 6 characters"
                           id="newPass" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Confirm New Password
                    </label>
                    <input type="password"
                           name="ConfirmPassword"
                           class="form-control"
                           placeholder="Re-enter password"
                           id="confirmPass" />
                    <small id="matchMsg"
                           style="color:red; display:none;">
                        Passwords do not match
                    </small>
                </div>

                <button type="submit"
                        id="submitBtn"
                        class="btn btn-success w-100">
                    Reset Password ✅
                </button>

                <a href="/Vendor/VendorAccount/Login"
                   class="btn btn-link w-100 text-center small mt-1">
                    ← Back to Login
                </a>
            </form>
        </div>
    </div>

    <script>
        var newPass     = document.getElementById('newPass');
        var confirmPass = document.getElementById('confirmPass');
        var matchMsg    = document.getElementById('matchMsg');
        var submitBtn   = document.getElementById('submitBtn');

        function checkMatch() {
            if (confirmPass.value.length > 0) {
                if (newPass.value !== confirmPass.value) {
                    matchMsg.style.display  = 'block';
                    submitBtn.disabled      = true;
                } else {
                    matchMsg.style.display  = 'none';
                    submitBtn.disabled      = false;
                }
            }
        }
        newPass.addEventListener('input', checkMatch);
        confirmPass.addEventListener('input', checkMatch);
    </script>
</body>
</html>
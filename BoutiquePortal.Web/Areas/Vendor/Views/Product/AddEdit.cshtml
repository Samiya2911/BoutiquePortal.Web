@model BoutiquePortal.Model.Models.Product

@{
    Layout = "~/Areas/Vendor/Views/Shared/_VendorLayout.cshtml";
    bool isEdit = Model.ProductId > 0;
    ViewBag.Title = isEdit ? "Edit Product" : "Add Product";
}

<div class="container mt-4">
    <h2 class="mb-4">@ViewBag.Title</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post"
          id="ProductForm"
          enctype="multipart/form-data"
          asp-area="Vendor"
          asp-controller="Product"
          asp-action="AddEdit">

        @Html.AntiForgeryToken()

        <input type="hidden" name="ProductId" value="@Model.ProductId" />
        <input type="hidden" name="ProductImage" value="@Model.ProductImage" />

        <div class="card shadow p-4">

            <!-- PRODUCT NAME -->
            <div class="mb-3">
                <label class="form-label">
                    Product Name <span class="text-danger">*</span>
                </label>
                <input type="text"
                       id="ProductName"
                       name="ProductName"
                       value="@Model.ProductName"
                       class="form-control"
                       placeholder="Enter product name" />
                <span id="err-ProductName" class="text-danger small"></span>
            </div>

            <!-- CATEGORY -->
            <div class="mb-3">
                <label class="form-label">
                    Category <span class="text-danger">*</span>
                </label>
                <select id="CategoryId" name="CategoryId" class="form-control">
                    <option value="">-- Select Category --</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var c in ViewBag.Categories)
                        {
                            <option value="@c.CategoryId"
                                    selected="@(c.CategoryId == Model.CategoryId)">
                                @c.CategoryName
                            </option>
                        }
                    }
                </select>
                <span id="err-CategoryId" class="text-danger small"></span>
            </div>

            <!-- SUB CATEGORY (loaded via AJAX) -->
            <div class="mb-3">
                <label class="form-label">
                    Sub Category <span class="text-danger">*</span>
                </label>
                <select id="SubCategoryId" name="SubCategoryId" class="form-control">
                    <option value="">-- Select Sub Category --</option>
                    @* Edit mode: pre-populated from ViewBag.SubCategories *@
                    @if (ViewBag.SubCategories != null)
                    {
                        foreach (var sc in ViewBag.SubCategories)
                        {
                            <option value="@sc.SubCategoryId"
                                    selected="@(sc.SubCategoryId == Model.SubCategoryId)">
                                @sc.SubCategoryName
                            </option>
                        }
                    }
                </select>
                <span id="err-SubCategoryId" class="text-danger small"></span>
            </div>

            <!-- BRAND NAME (read only - from session/vendor profile) -->
            <div class="mb-3">
                <label class="form-label">Brand Name</label>
                <input type="text"
                       id="BrandName"
                       name="BrandName"
                       @* value="@Model.BrandName" *@
                       value="@Context.Session.GetString("BrandName")"
                       class="form-control"
                       readonly
                      @*  placeholder="From your vendor profile" *@ />
                <small class="text-muted">
                    Auto-filled from your brand —
                    cannot be changed here
                </small>
            </div>

            <!-- PRICE & DISCOUNT PRICE -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        Price (&#8377;) <span class="text-danger">*</span>
                    </label>
                    <input type="number"
                           step="0.01"
                           id="Price"
                           name="Price"
                           value="@Model.Price"
                           class="form-control"
                           placeholder="0.00" />
                    <span id="err-Price" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Discount Price (&#8377;)</label>
                    <input type="number"
                           step="0.01"
                           id="DiscountPrice"
                           name="DiscountPrice"
                           value="@Model.DiscountPrice"
                           class="form-control"
                           placeholder="0.00 (optional)" />
                </div>
            </div>

            <!-- QUANTITY -->
            <div class="mb-3">
                <label class="form-label">Quantity</label>
                <input type="number"
                       id="Quantity"
                       name="Quantity"
                       value="@Model.Quantity"
                       class="form-control"
                       placeholder="0" />
                <span id="err-Quantity" class="text-danger small"></span>
            </div>


            <!-- ======= SIZES SECTION ======= -->
            <div class="mb-3">
                <label class="form-label fw-bold">
                    Product Sizes &amp; Stock
                    <small class="text-muted fw-normal">
                        (Add sizes with individual quantities)
                    </small>
                </label>

                <div id="sizes-container">
                    @{
                        var existingSizes = ViewBag.Sizes as
                        List<BoutiquePortal.Model.Models.ProductSize>
                        ?? new List<BoutiquePortal.Model.Models.ProductSize>();
                    }

                    @if (existingSizes.Any())
                    {
                        foreach (var s in existingSizes)
                        {
                            <div class="size-row d-flex gap-2 mb-2 align-items-center">
                                <input type="text"
                                       name="SizeName"
                                       value="@s.SizeName"
                                       class="form-control"
                                       style="max-width:120px;"
                                       placeholder="e.g. M" />
                                <input type="number"
                                       name="SizeQty"
                                       value="@s.Quantity"
                                       class="form-control"
                                       style="max-width:100px;"
                                       placeholder="Stock"
                                       min="0" />
                                <span class="text-muted small">units</span>
                                <button type="button"
                                        onclick="removeSize(this)"
                                        class="btn btn-sm btn-danger">
                                    ✕
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="size-row d-flex gap-2 mb-2 align-items-center">
                            <input type="text"
                                   name="SizeName"
                                   class="form-control"
                                   style="max-width:120px;"
                                   placeholder="e.g. M" />
                            <input type="number"
                                   name="SizeQty"
                                   class="form-control"
                                   style="max-width:100px;"
                                   placeholder="Stock"
                                   min="0" />
                            <span class="text-muted small">units</span>
                            <button type="button"
                                    onclick="removeSize(this)"
                                    class="btn btn-sm btn-danger">
                                ✕
                            </button>
                        </div>
                    }
                </div>

                <!-- Quick Add Buttons -->
                <div class="mt-2 mb-2">
                    <small class="text-muted me-1">Quick add:</small>
                    <button type="button" onclick="quickAddSize('S')"
                            class="btn btn-sm btn-outline-secondary ms-1"
                            style="font-size:11px; padding:2px 8px;">
                        S
                    </button>
                    <button type="button" onclick="quickAddSize('M')"
                            class="btn btn-sm btn-outline-secondary ms-1"
                            style="font-size:11px; padding:2px 8px;">
                        M
                    </button>
                    <button type="button" onclick="quickAddSize('L')"
                            class="btn btn-sm btn-outline-secondary ms-1"
                            style="font-size:11px; padding:2px 8px;">
                        L
                    </button>
                    <button type="button" onclick="quickAddSize('XL')"
                            class="btn btn-sm btn-outline-secondary ms-1"
                            style="font-size:11px; padding:2px 8px;">
                        XL
                    </button>
                    <button type="button" onclick="quickAddSize('XXL')"
                            class="btn btn-sm btn-outline-secondary ms-1"
                            style="font-size:11px; padding:2px 8px;">
                        XXL
                    </button>
                    <button type="button" onclick="quickAddSize('Free Size')"
                            class="btn btn-sm btn-outline-secondary ms-1"
                            style="font-size:11px; padding:2px 8px;">
                        Free Size
                    </button>
                </div>

                <button type="button"
                        onclick="addSizeRow()"
                        class="btn btn-sm btn-outline-primary">
                    + Add Size
                </button>

                <small class="text-muted d-block mt-1">
                    Leave size name empty to skip that row.
                </small>
            </div>


            <!-- DESCRIPTION -->
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea id="Description"
                          name="Description"
                          class="form-control"
                          rows="3"
                          placeholder="Enter product description">@Model.Description</textarea>
            </div>

            <!-- IMAGE UPLOAD -->
            <div class="mb-3">
                <label class="form-label">Product Image</label>
                <input type="file"
                       id="ImageFile"
                       name="ImageFile"
                       class="form-control"
                       accept="image/jpeg,image/jpg,image/png" />
                <span id="err-Image" class="text-danger small"></span>

                @if (!string.IsNullOrEmpty(Model.ProductImage))
                {
                    <div class="mt-2">
                        <small class="text-muted">Current Image:</small><br />
                        <img src="~/images/product/@Model.ProductImage"
                             id="imagePreview"
                             width="120" height="120"
                             style="object-fit:cover; border-radius:6px; border:1px solid #ddd;"
                             onerror="this.style.display='none'" />
                    </div>
                }
                else
                {
                    <div class="mt-2">
                        <img id="imagePreview" src="#" width="120" height="120"
                             style="object-fit:cover; border-radius:6px;
                                        border:1px solid #ddd; display:none;" />
                    </div>
                }
            </div>

            <!-- IS ACTIVE -->
            <div class="form-check mb-3">
                <input type="checkbox"
                       name="IsActive"
                       value="true"
                       id="IsActive"
                       class="form-check-input"
                       @(Model.IsActive ? "checked" : "") />
                <label class="form-check-label">Active</label>
            </div>

            <!-- BUTTONS -->
            <div class="mt-3">
                <button type="submit" class="btn btn-primary btn-sm">
                    @(isEdit ? "Update" : "Save")
                </button>
                <a href="/Vendor/Product/Index" class="btn btn-secondary btn-sm ms-2">
                    Cancel
                </a>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    @* Inject edit-mode IDs BEFORE product.js — same pattern as Admin *@
    @if (isEdit)
    {
        <script>
            var selectedCategoryId    = @Model.CategoryId;
            var selectedSubCategoryId = @(Model.SubCategoryId.HasValue? Model.SubCategoryId.Value.ToString() : "0");
        </script>
    }
    <script src="~/js/vendor/product.js"></script>
    <script>
        // ======= SIZE MANAGEMENT =======
        function addSizeRow() {
            var row = '<div class="size-row d-flex gap-2 mb-2 align-items-center">'
                + '<input type="text" name="SizeName" class="form-control"'
                + ' style="max-width:120px;" placeholder="e.g. XL" />'
                + '<input type="number" name="SizeQty" class="form-control"'
                + ' style="max-width:100px;" placeholder="Stock" min="0" />'
                + '<span class="text-muted small">units</span>'
                + '<button type="button" onclick="removeSize(this)"'
                + ' class="btn btn-sm btn-danger">✕</button>'
                + '</div>';
            document.getElementById('sizes-container')
                    .insertAdjacentHTML('beforeend', row);
        }

        function removeSize(btn) {
            btn.closest('.size-row').remove();
        }

        function quickAddSize(sizeName) {
            // Check if size already exists
            var existing = Array.from(
                document.querySelectorAll('input[name="SizeName"]'))
                .find(function (i) {
                    return i.value.trim() === sizeName;
                });

            if (existing) {
                existing.focus();
                existing.style.border = '2px solid #e74c3c';
                setTimeout(function () {
                    existing.style.border = '';
                }, 2000);
                return;
            }

            var row = '<div class="size-row d-flex gap-2 mb-2 align-items-center">'
                + '<input type="text" name="SizeName" value="' + sizeName + '"'
                + ' class="form-control" style="max-width:120px;"'
                + ' placeholder="e.g. ' + sizeName + '" />'
                + '<input type="number" name="SizeQty" value="0"'
                + ' class="form-control" style="max-width:100px;"'
                + ' placeholder="Stock" min="0" />'
                + '<span class="text-muted small">units</span>'
                + '<button type="button" onclick="removeSize(this)"'
                + ' class="btn btn-sm btn-danger">✕</button>'
                + '</div>';
            document.getElementById('sizes-container')
                    .insertAdjacentHTML('beforeend', row);
        }
    </script>
}
@model BoutiquePortal.Model.ViewModels.ForgotPasswordVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Forgot Password — Boutique</title>
    <link href="~/assets/vendor/bootstrap/css/bootstrap.min.css"
          rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 20px 50px rgba(0,0,0,.2);
            max-width: 420px;
            width: 100%;
        }

        .card-header {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            color: white;
            border-radius: 16px 16px 0 0 !important;
            padding: 1.5rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">🔑 Forgot Password</h4>
            <small class="opacity-75">Enter your registered email</small>
        </div>
        <div class="card-body p-4">

            @if (ViewBag.TokenGenerated == true)
            {
                <div class="alert alert-success">
                    ✅ Reset link generated!
                    <hr />
                    <a href="@ViewBag.ResetLink"
                       class="btn btn-danger w-100">
                        Reset My Password →
                    </a>
                    <p class="text-muted small mt-2 mb-0">
                        ⏰ Expires in 30 minutes.
                    </p>
                </div>
            }
            else
            {
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger small py-2">
                        @foreach (var e in ViewData.ModelState.Values
                                        .SelectMany(v => v.Errors))
                        {
                            <div>@e.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post"
                      action="/Customer/CustomerAccount/ForgotPassword">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" name="Email"
                               class="form-control"
                               placeholder="your@email.com" />
                    </div>
                    <button type="submit" class="btn btn-danger w-100">
                        Send Reset Link
                    </button>
                    <a href="/Customer/CustomerAccount/Login"
                       class="btn btn-link w-100 text-center small mt-1">
                        ← Back to Login
                    </a>
                </form>
            }
        </div>
    </div>
</body>
</html>
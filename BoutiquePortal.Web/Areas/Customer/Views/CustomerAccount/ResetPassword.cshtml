@model BoutiquePortal.Model.ViewModels.ResetPasswordVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reset Password</title>
    <link href="~/assets/vendor/bootstrap/css/bootstrap.min.css"
          rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg,#f093fb,#f5576c);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 20px 50px rgba(0,0,0,.2);
            max-width: 420px;
            width: 100%;
        }

        .card-header {
            background: linear-gradient(135deg,#f093fb,#f5576c);
            color: white;
            border-radius: 16px 16px 0 0 !important;
            padding: 1.5rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">🔒 Reset Password</h4>
            <small class="opacity-75">Enter your new password</small>
        </div>
        <div class="card-body p-4">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger small py-2">
                    @foreach (var e in ViewData.ModelState.Values
                                    .SelectMany(v => v.Errors))
                    {
                        <div>@e.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post"
                  action="/Customer/CustomerAccount/ResetPassword">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Token" value="@Model.Token" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">New Password</label>
                    <input type="password" name="NewPassword"
                           id="newPass" class="form-control"
                           placeholder="Min 6 characters" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Confirm Password
                    </label>
                    <input type="password" name="ConfirmPassword"
                           id="confirmPass" class="form-control"
                           placeholder="Re-enter password" />
                    <small id="matchMsg" style="color:red; display:none;">
                        Passwords do not match
                    </small>
                </div>

                <button type="submit" id="submitBtn"
                        class="btn btn-danger w-100">
                    Reset Password ✅
                </button>
                <a href="/Customer/CustomerAccount/Login"
                   class="btn btn-link w-100 text-center small mt-1">
                    ← Back to Login
                </a>
            </form>
        </div>
    </div>
    <script>
        var np = document.getElementById('newPass');
        var cp = document.getElementById('confirmPass');
        var mm = document.getElementById('matchMsg');
        var sb = document.getElementById('submitBtn');
        function check() {
            if (cp.value.length > 0) {
                if (np.value !== cp.value) { mm.style.display='block'; sb.disabled=true; }
                else { mm.style.display='none'; sb.disabled=false; }
            }
        }
        np.addEventListener('input', check);
        cp.addEventListener('input', check);
    </script>
</body>
</html>
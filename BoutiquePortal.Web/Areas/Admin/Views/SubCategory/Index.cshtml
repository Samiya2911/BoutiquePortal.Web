@model IEnumerable<BoutiquePortal.Model.Models.SubCategory>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "SubCategories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>SubCategory List</h2>

        <a href="/Admin/SubCategory/AddEdit" class="btn btn-success">
            <i class="fa fa-plus"></i> Add SubCategory
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body table-responsive">

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Image</th>  
                        <th>SubCategory</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center">No Data Found</td>
                        </tr>
                    }
                    else
                    {
                        int i = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@(i)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.SubCategoryImage))
                                    {
                                        <img src="~/images/subcategory/@item.SubCategoryImage"
                                             width="60" height="60"
                                             style="object-fit:cover; border-radius:4px;"
                                             onerror="this.style.display='none'" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Image</span>
                                    }
                                </td>
                                <td>@item.SubCategoryName</td>
                                <td>@item.CategoryName</td>
                                <td>@item.Description</td>

                                <td>
                                    <span class="badge bg-@(item.IsActive ? "success" : "danger")">
                                        @(item.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>

                                <td>@item.CreatedDate.ToString("dd MMM yyyy")</td>

                                <td>
                                    <a href="/Admin/SubCategory/AddEdit/@item.SubCategoryId"
                                       class="btn btn-sm btn-primary">
                                        Edit
                                    </a>

                                    <form action="/Admin/SubCategory/Delete"
                                          method="post"
                                          class="delete-form d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.SubCategoryId" />

                                        <button type="submit" class="btn btn-sm btn-danger">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/subcategory.js"></script>
}
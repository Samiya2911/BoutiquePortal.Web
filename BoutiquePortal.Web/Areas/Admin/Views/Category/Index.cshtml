@model IEnumerable<BoutiquePortal.Model.Models.Category>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Categories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>Category List</h2>
        <a href="/Admin/Category/AddEdit" class="btn btn-success">
            <i class="fa fa-plus"></i> Add Category
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="fa fa-inbox fa-2x mb-2 d-block"></i>No Data Found
                            </td>
                        </tr>
                    }
                    else
                    {

                        int i = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@(i)</td>
                              
                                <td>
                                    @if (!string.IsNullOrEmpty(item.CategoryImage))
                                    {
                                        <img src="~/images/category/@item.CategoryImage"
                                             width="60" height="60"
                                             style="object-fit:cover; border-radius:4px;"
                                             onerror="this.style.display='none'" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Image</span>
                                    }
                                </td>

                                <td>@item.CategoryName</td>
                                <td>@item.Description</td>
                                <td>
                                    <span class="badge bg-@(item.IsActive ? "success" : "danger")">
                                        @(item.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>@item.CreatedDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a href="/Admin/Category/AddEdit/@item.CategoryId"
                                       class="btn btn-sm btn-primary">
                                        <i class="fa fa-edit"></i> Edit
                                    </a>

                                    <form action="/Admin/Category/Delete"
                                          method="post"
                                          class="delete-form"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.CategoryId" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fa fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/category.js"></script>
}
